              "  pm.expect(body.error).to.eql(null);",
              "});",
              "const last = pm.environment.get('lastExpense');",
              "pm.test('same expense as first response', function () {",
              "  pm.expect(JSON.stringify(body.data.expense)).to.eql(last);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
